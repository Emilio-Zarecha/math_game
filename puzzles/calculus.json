      { "id": "s3", "fromLatex": "3(x^2+1)^2 \\cdot 2x", "toLatex": "6x(x^2+1)^2", "paletteRef": "p2", "dropTargets": ["3(x^2+1)^2 \\cdot 2x"], "description": "Multiply constants: 3 × 2 = 6" }
