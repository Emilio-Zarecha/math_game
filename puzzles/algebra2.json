      { "id": "s2", "fromLatex": "S = \\frac{a}{1-r}", "toLatex": "S = \\frac{1}{1 - \\frac{1}{2}}", "paletteRef": "p2", "dropTargets": ["\\frac{a}{1-r}"], "description": "Apply formula S = a/(1−r) with a=1, r=½" },
