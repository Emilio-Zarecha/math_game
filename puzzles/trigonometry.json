      { "id": "s3", "fromLatex": "\\cos^2(\\theta) = 1 - \\frac{9}{25}", "toLatex": "\\cos^2(\\theta) = \\frac{16}{25}", "paletteRef": null, "dropTargets": [], "description": "1 − 9/25 = 16/25" },
      { "id": "s3a", "fromLatex": "\\sqrt{16} = 4 \\text{ and } \\sqrt{25} = 5", "toLatex": "\\sqrt{\\frac{16}{25}} = \\frac{\\sqrt{16}}{\\sqrt{25}} = \\frac{4}{5} \\quad (\\sqrt{16}=4,\\ \\sqrt{25}=5)", "paletteRef": null, "dropTargets": [], "description": "Compute: √16 = 4 (since 4² = 16) and √25 = 5 (since 5² = 25)" },
