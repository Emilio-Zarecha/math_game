      { "id": "s2", "fromLatex": "\\cos^2(\\theta) = 1 - \\sin^2(\\theta)", "toLatex": "\\cos^2(\\theta) = 1 - \\frac{9}{25}", "paletteRef": null, "dropTargets": [], "description": "Substitute sin(θ)=3/5, so sin²(θ)=9/25" },
